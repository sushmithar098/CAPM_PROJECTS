{
  "name": "task5",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/hana": "^2.7.0",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "axios": "^1.13.6",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^0.4.1",
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0",
    "jest": "^30.3.0",
    "ui5-task-zipper": "^3.6.0"
  },
  "scripts": {
    "test": "npx jest test/testcase.test.js",
    "start": "cds-serve",
    "watch-adminprofile": "cds watch --profile hybrid --open adminprofile/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-user": "cds watch --profile hybrid --open user/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-adminusers": "cds watch --profile hybrid --open adminusers/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "cds": {
    "requires": {
      "[development]": {
        "auth": {
          "kind": "basic",
          "users": {
            "scott": {
              "password": "123",
              "roles": [
                "admin"
              ]
            },
            "bob": {
              "roles": [
                "support"
              ]
            }
          }
        }
      },
      "[production]": {
        "db": "hana",
        "auth": "xsuaa"
      },
      "destinations": true,
      "html5-repo": true,
      "workzone": true
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/user",
    "app/adminusers",
    "app/adminprofile"
  ]
}
